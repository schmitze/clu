#!/usr/bin/env bash
# ============================================================
# clu Launcher
# ============================================================
# Usage:
#   clu                    → workspace mode (all projects, switch freely)
#   clu <project>          → launch specific project
#   clu new <name>         → create new project
#   clu list               → list all projects
#   clu summarize <project> → run post-session summarizer
#   clu check <project>    → check memory staleness
#   clu import             → import Claude Code session history
#   clu bootstrap          → agent-guided onboarding interview
#   clu heartbeat          → run maintenance heartbeat (or via cron)
#   clu --adapter <name> <project>  → override adapter
#   clu --persona <name> <project>  → override persona
# ============================================================

set -euo pipefail

# ── Resolve paths ─────────────────────────────────────────────

AGENT_HOME="${CLU_HOME:-$HOME/.clu}"
CONFIG_FILE="$AGENT_HOME/config.yaml"

# ── Portable helpers (Linux + macOS) ─────────────────────────

# Portable sed in-place (macOS sed requires '' suffix)
_sed_i() {
    if sed --version 2>/dev/null | grep -q GNU; then
        sed -i "$@"
    else
        sed -i '' "$@"
    fi
}

# Portable date string to epoch (GNU: date -d, macOS: date -j -f)
_date_to_epoch() {
    local datestr="$1"
    date -d "$datestr" +%s 2>/dev/null \
        || date -j -f "%Y-%m-%d" "$datestr" +%s 2>/dev/null \
        || echo "0"
}

# Minimal YAML parser (covers flat keys and simple nesting)
# For production use, consider yq. This handles the basics.
yaml_get() {
    local file="$1" key="$2"
    grep -E "^${key}:" "$file" 2>/dev/null | head -1 | sed "s/^${key}:[[:space:]]*//" | sed 's/^"//' | sed 's/"$//'
}

# ── Load config ───────────────────────────────────────────────

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "❌ Config not found at $CONFIG_FILE"
    echo "   Run the install script first, or set CLU_HOME."
    exit 1
fi

DEFAULT_ADAPTER=$(yaml_get "$CONFIG_FILE" "default_adapter")
DEFAULT_PROJECT=$(yaml_get "$CONFIG_FILE" "default_project")
STALENESS_DAYS=$(yaml_get "$CONFIG_FILE" "memory_staleness_days")
DYNAMIC_PERSONAS=$(yaml_get "$CONFIG_FILE" "dynamic_personas")

# ── Argument parsing ──────────────────────────────────────────

ADAPTER="$DEFAULT_ADAPTER"
PERSONA_OVERRIDE=""
COMMAND=""
PROJECT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --adapter)
            ADAPTER="$2"
            shift 2
            ;;
        --persona)
            PERSONA_OVERRIDE="$2"
            shift 2
            ;;
        new|list|summarize|check|bootstrap|heartbeat|import|dashboard)
            COMMAND="$1"
            shift
            PROJECT="${1:-}"
            shift || true
            ;;
        -h|--help)
            head -15 "$0" | grep "^#" | sed 's/^# *//'
            exit 0
            ;;
        *)
            PROJECT="$1"
            shift
            ;;
    esac
done

# ── Commands ──────────────────────────────────────────────────

cmd_list() {
    echo "📂 Available projects:"
    echo ""
    for dir in "$AGENT_HOME"/projects/*/; do
        [[ -d "$dir" ]] || continue
        local name
        name=$(basename "$dir")
        local desc
        desc=$(yaml_get "$dir/project.yaml" "description" 2>/dev/null || echo "")
        local ptype
        ptype=$(yaml_get "$dir/project.yaml" "type" 2>/dev/null || echo "mixed")
        printf "  %-20s [%s]  %s\n" "$name" "$ptype" "$desc"
    done
    echo ""
}

cmd_new() {
    local name="$1"
    if [[ -z "$name" ]]; then
        echo "Usage: clu new <project-name>"
        exit 1
    fi

    local target="$AGENT_HOME/projects/$name"
    if [[ -d "$target" ]]; then
        echo "❌ Project '$name' already exists at $target"
        exit 1
    fi

    local today
    today=$(date +%Y-%m-%d)

    echo "🆕 Creating project: $name"
    cp -r "$AGENT_HOME/templates/new-project" "$target"

    # Create daily log directory
    mkdir -p "$target/memory/days"

    # Replace template placeholders
    find "$target" -type f -name "*.yaml" -o -name "*.md" | while read -r f; do
        _sed_i "s/{{PROJECT_NAME}}/$name/g" "$f"
        _sed_i "s/{{DATE}}/$today/g" "$f"
    done

    echo "✅ Created at $target"
    echo ""
    echo "Next steps:"
    echo "  1. Edit $target/project.yaml (set repo_path, type, description)"
    echo "  2. Edit $target/constraints.md (add project-specific rules)"
    echo "  3. Run: clu $name"
    echo ""
}

cmd_check() {
    local name="$1"
    local project_dir="$AGENT_HOME/projects/$name"
    if [[ ! -d "$project_dir" ]]; then
        echo "❌ Project '$name' not found."
        exit 1
    fi

    echo "🔍 Memory staleness check for: $name (threshold: ${STALENESS_DAYS}d)"
    echo ""

    local today_epoch
    today_epoch=$(date +%s)

    for mf in "$project_dir"/memory/*.md "$AGENT_HOME"/shared/memory/*.md "$AGENT_HOME"/shared/agent/*.md; do
        [[ -f "$mf" ]] || continue
        local verified
        verified=$(grep "last_verified:" "$mf" 2>/dev/null | head -1 | sed 's/.*last_verified:[[:space:]]*//')
        if [[ -n "$verified" ]]; then
            local v_epoch
            v_epoch=$(_date_to_epoch "$verified")
            local age_days=$(( (today_epoch - v_epoch) / 86400 ))
            local status="✅"
            if [[ $age_days -ge $STALENESS_DAYS ]]; then
                status="⚠️  STALE ($age_days days)"
            fi
            printf "  %-40s %s  (verified: %s)\n" "$(basename "$mf")" "$status" "$verified"
        else
            printf "  %-40s ❓  no last_verified header\n" "$(basename "$mf")"
        fi
    done
    echo ""
}

cmd_summarize() {
    local name="$1"
    local project_dir="$AGENT_HOME/projects/$name"
    if [[ ! -d "$project_dir" ]]; then
        echo "❌ Project '$name' not found."
        exit 1
    fi

    echo "📝 Post-session summarizer for: $name"
    echo "   This will ask the adapter to generate a session summary"
    echo "   and propose appending it to journal.md."
    echo ""

    # Delegate to adapter's summarize function
    local adapter_script="$AGENT_HOME/adapters/${ADAPTER}.sh"
    if [[ -f "$adapter_script" ]]; then
        source "$adapter_script"
        adapter_summarize "$project_dir" "$AGENT_HOME"
    else
        echo "❌ Adapter '$ADAPTER' not found at $adapter_script"
        exit 1
    fi
}

# ── Workspace context (multi-project mode) ───────────────────

assemble_workspace_context() {
    local persona_name="${PERSONA_OVERRIDE:-default}"

    local core_prompt
    core_prompt=$(cat "$AGENT_HOME/shared/core-prompt.md")

    # Persona block
    local persona_block=""
    local persona_file="$AGENT_HOME/personas/${persona_name}.md"
    if [[ -f "$persona_file" ]]; then
        persona_block=$(cat "$persona_file")
    else
        persona_block=$(cat "$AGENT_HOME/personas/default.md")
    fi

    # Router
    local router_block=""
    if [[ "$DYNAMIC_PERSONAS" == "true" ]]; then
        router_block=$(cat "$AGENT_HOME/personas/_router.md")
    fi

    # Global constraints
    local global_constraints=""
    [[ -f "$AGENT_HOME/shared/constraints.md" ]] && global_constraints=$(cat "$AGENT_HOME/shared/constraints.md")

    # Trait reference (linked, not inline — saves ~6k chars)
    local trait_reference=""
    if [[ -f "$AGENT_HOME/personas/_traits.md" ]]; then
        trait_reference="## Big Five Trait System"$'\n\n'
        trait_reference+="Full trait reference: \`$AGENT_HOME/personas/_traits.md\`"$'\n'
        trait_reference+="Read this file when you need to interpret persona trait scores."
    fi

    # Shared memory (user + agent)
    local shared_memory=""
    shared_memory=$(_load_memory_l1 "$AGENT_HOME/shared/memory")
    local agent_memory=""
    [[ -d "$AGENT_HOME/shared/agent" ]] && agent_memory=$(_load_memory_l1 "$AGENT_HOME/shared/agent")

    # ── Build project index ───────────────────────────────────
    local project_index=""
    project_index+="## Available Projects"$'\n\n'
    project_index+="You can work on any of these projects. Switch by reading the"$'\n'
    project_index+="project's memory files. Announce switches with:"$'\n'
    project_index+="\`[→ Project: <name> (<type>)]\`"$'\n\n'

    for dir in "$AGENT_HOME"/projects/*/; do
        [[ -d "$dir" ]] || continue
        local pname
        pname=$(basename "$dir")
        local ptype
        ptype=$(yaml_get "$dir/project.yaml" "type" 2>/dev/null || echo "mixed")
        local pdesc
        pdesc=$(yaml_get "$dir/project.yaml" "description" 2>/dev/null || echo "")
        local prepo
        prepo=$(yaml_get "$dir/project.yaml" "repo_path" 2>/dev/null || echo "null")
        local ppersona
        ppersona=$(yaml_get "$dir/project.yaml" "default_persona" 2>/dev/null || echo "default")

        project_index+="### $pname"$'\n'
        project_index+="- **Type:** $ptype"$'\n'
        [[ -n "$pdesc" ]] && project_index+="- **Description:** $pdesc"$'\n'
        [[ "$prepo" != "null" && -n "$prepo" ]] && project_index+="- **Repo:** \`$prepo\`"$'\n'
        project_index+="- **Default persona:** $ppersona"$'\n'
        project_index+="- **Project dir:** \`$dir\`"$'\n'

        # Only list memory files that have real content (non-empty abstracts)
        local has_content_files=false
        local content_files=""
        for mf in "$dir"/memory/*.md; do
            [[ -f "$mf" ]] || continue
            local abstract
            abstract=$(grep "^abstract:" "$mf" 2>/dev/null | head -1 | sed 's/^abstract:[[:space:]]*//' | sed 's/^"//' | sed 's/"$//')
            # Skip files with empty/placeholder abstracts
            if [[ -n "$abstract" && "$abstract" != *"Empty"* && "$abstract" != *"no entries"* ]]; then
                content_files+="  - \`$(basename "$mf")\` — $abstract"$'\n'
                has_content_files=true
            fi
        done

        if [[ "$has_content_files" == "true" ]]; then
            project_index+="- **Memory:**"$'\n'
            project_index+="$content_files"
        fi
        project_index+=$'\n'
    done

    # ── Build workspace instructions ──────────────────────────
    local workspace_block=""
    workspace_block+="## Workspace Mode — Multi-Project Navigation"$'\n\n'
    workspace_block+="You are in **workspace mode**. The user has not selected a specific"$'\n'
    workspace_block+="project. You have an overview of all projects and can:"$'\n\n'
    workspace_block+="1. **Switch projects** — when the user says \"let's work on X\" or"$'\n'
    workspace_block+="   starts discussing a specific project, read its memory files and"$'\n'
    workspace_block+="   constraints. Announce: \`[→ Project: X (type)]\`"$'\n'
    workspace_block+="   Switch to the project's default persona if dynamic_personas is enabled."$'\n\n'
    workspace_block+="2. **Create new projects** — when the user wants to start something new:"$'\n'
    workspace_block+="   - Ask for: project name, type (software/research/writing/strategy/mixed),"$'\n'
    workspace_block+="     description, and repo path (if applicable)"$'\n'
    workspace_block+="   - Copy the template: \`cp -r $AGENT_HOME/templates/new-project $AGENT_HOME/projects/<name>\`"$'\n'
    workspace_block+="   - Create daily log dir: \`mkdir -p $AGENT_HOME/projects/<name>/memory/days\`"$'\n'
    workspace_block+="   - Fill in \`project.yaml\` with name, type, description, repo_path"$'\n'
    workspace_block+="   - Replace \`{{PROJECT_NAME}}\` and \`{{DATE}}\` in all template files"$'\n'
    workspace_block+="   - Announce: \`[✨ Created project: <name> (<type>)]\`"$'\n'
    workspace_block+="   - Then switch into the new project context"$'\n\n'
    workspace_block+="3. **Work across projects** — reference decisions or patterns from one"$'\n'
    workspace_block+="   project while working in another. All memory files are accessible."$'\n\n'
    workspace_block+="4. **Project memory is on-demand** — you have L0 abstracts for all projects."$'\n'
    workspace_block+="   Only read full memory files when actively working on that project."$'\n\n'

    workspace_block+="$project_index"

    # ── Substitute variables ──────────────────────────────────

    local prompt="$core_prompt"
    prompt="${prompt//\{\{PERSONA_BLOCK\}\}/$persona_block}"
    prompt="${prompt//\{\{ROUTER_BLOCK\}\}/$router_block}"
    prompt="${prompt//\{\{TRAIT_REFERENCE\}\}/$trait_reference}"
    prompt="${prompt//\{\{GLOBAL_CONSTRAINTS\}\}/$global_constraints}"
    prompt="${prompt//\{\{PROJECT_CONSTRAINTS\}\}/[Workspace mode — project constraints loaded on switch]}"
    prompt="${prompt//\{\{SHARED_MEMORY\}\}/$shared_memory}"
    prompt="${prompt//\{\{AGENT_MEMORY\}\}/$agent_memory}"
    prompt="${prompt//\{\{PROJECT_MEMORY\}\}/$workspace_block}"
    prompt="${prompt//\{\{STALENESS_DAYS\}\}/$STALENESS_DAYS}"
    prompt="${prompt//\{\{REPO_PATH\}\}/[Workspace mode — repo path set per project]}"

    export AGENT_PROMPT="$prompt"
    export AGENT_PROJECT_NAME="_workspace"
    export AGENT_PROJECT_DIR="$AGENT_HOME/projects"
    export AGENT_PROJECT_TYPE="workspace"
    # Use default_workdir if set, otherwise $HOME
    local default_workdir
    default_workdir=$(grep "^default_workdir:" "$AGENT_HOME/config.yaml" 2>/dev/null \
        | head -1 | sed 's/.*default_workdir:[[:space:]]*//')
    default_workdir="${default_workdir:-$HOME}"
    [[ "$default_workdir" == "null" || -z "$default_workdir" ]] && default_workdir="$HOME"
    default_workdir="${default_workdir/#\~/$HOME}"
    export AGENT_REPO_PATH="$default_workdir"
    export AGENT_PERSONA="$persona_name"
    export AGENT_HOME="$AGENT_HOME"

    # Pass context for budget enforcement to rebuild if needed
    _BUDGET_PROJECT_CONSTRAINTS="[Workspace mode — project constraints loaded on switch]"
    _BUDGET_PROJECT_MEMORY="$workspace_block"
    _enforce_budget || true
}

# ── Prompt budget enforcement ─────────────────────────────────
#
# After assembly, checks if AGENT_PROMPT exceeds the configured
# char budget. If so, progressively reduces detail:
#   Tier 1: Agent memory → abstracts only
#   Tier 2: Project index → compact (name/type/repo only)
#   Tier 3: Shared memory → abstracts only
# Warns if still over budget after all tiers.

PROMPT_BUDGET=$(yaml_get "$CONFIG_FILE" "prompt_budget_chars")
PROMPT_BUDGET="${PROMPT_BUDGET:-38000}"

_load_memory_l0() {
    # Compact loader: abstracts + paths only, no inline content
    local dir="$1"
    local output=""
    for mf in "$dir"/*.md; do
        [[ -f "$mf" ]] || continue
        local mf_basename
        mf_basename=$(basename "$mf")
        local abstract
        abstract=$(grep "^abstract:" "$mf" 2>/dev/null | head -1 | sed 's/^abstract:[[:space:]]*//' | sed 's/^"//' | sed 's/"$//')
        output+="- \`$mf\`"
        [[ -n "$abstract" ]] && output+=" — $abstract"
        output+=$'\n'
    done
    echo "$output"
}

_build_compact_project_index() {
    # Minimal project listing: name, type, repo path only
    local output=""
    output+="## Available Projects"$'\n\n'
    for dir in "$AGENT_HOME"/projects/*/; do
        [[ -d "$dir" ]] || continue
        local pname ptype prepo
        pname=$(basename "$dir")
        ptype=$(yaml_get "$dir/project.yaml" "type" 2>/dev/null || echo "mixed")
        prepo=$(yaml_get "$dir/project.yaml" "repo_path" 2>/dev/null || echo "")
        output+="- **$pname** ($ptype)"
        [[ -n "$prepo" && "$prepo" != "null" ]] && output+=" — \`$prepo\`"
        output+=" — dir: \`$dir\`"
        output+=$'\n'
    done
    echo "$output"
}

_enforce_budget() {
    local current_size=${#AGENT_PROMPT}
    if [[ "$current_size" -le "$PROMPT_BUDGET" ]]; then
        return 0
    fi

    echo "   ⚠ Prompt size ${current_size} > budget ${PROMPT_BUDGET}. Trimming..."

    # We rebuild the prompt with progressively lower detail.
    # Strategy: re-substitute specific {{PLACEHOLDERS}} in the core
    # template with compact versions, keeping a copy of the template.
    local core_prompt
    core_prompt=$(cat "$AGENT_HOME/shared/core-prompt.md")

    # Reload persona/router/constraints/trait (these are small, keep as-is)
    local persona_name="${AGENT_PERSONA:-default}"
    local persona_file="$AGENT_HOME/personas/${persona_name}.md"
    local persona_block=""
    [[ -f "$persona_file" ]] && persona_block=$(cat "$persona_file") || persona_block=$(cat "$AGENT_HOME/personas/default.md")

    local router_block=""
    [[ "$DYNAMIC_PERSONAS" == "true" && -f "$AGENT_HOME/personas/_router.md" ]] && router_block=$(cat "$AGENT_HOME/personas/_router.md")

    local global_constraints=""
    [[ -f "$AGENT_HOME/shared/constraints.md" ]] && global_constraints=$(cat "$AGENT_HOME/shared/constraints.md")

    local trait_reference=""
    if [[ -f "$AGENT_HOME/personas/_traits.md" ]]; then
        trait_reference="Full trait reference: \`$AGENT_HOME/personas/_traits.md\`"
    fi

    # Start with current detail levels, then reduce tier by tier
    local shared_memory agent_memory project_memory project_constraints
    shared_memory=$(_load_memory_l1 "$AGENT_HOME/shared/memory")
    agent_memory=$(_load_memory_l1 "$AGENT_HOME/shared/agent" 2>/dev/null || echo "")
    project_constraints="${_BUDGET_PROJECT_CONSTRAINTS:-[Workspace mode — project constraints loaded on switch]}"
    project_memory="${_BUDGET_PROJECT_MEMORY:-}"

    # ── Tier 1: Agent memory → abstracts only ─────────────────
    agent_memory=$(_load_memory_l0 "$AGENT_HOME/shared/agent" 2>/dev/null || echo "")
    local prompt="$core_prompt"
    prompt="${prompt//\{\{PERSONA_BLOCK\}\}/$persona_block}"
    prompt="${prompt//\{\{ROUTER_BLOCK\}\}/$router_block}"
    prompt="${prompt//\{\{TRAIT_REFERENCE\}\}/$trait_reference}"
    prompt="${prompt//\{\{GLOBAL_CONSTRAINTS\}\}/$global_constraints}"
    prompt="${prompt//\{\{PROJECT_CONSTRAINTS\}\}/$project_constraints}"
    prompt="${prompt//\{\{SHARED_MEMORY\}\}/$shared_memory}"
    prompt="${prompt//\{\{AGENT_MEMORY\}\}/$agent_memory}"
    prompt="${prompt//\{\{PROJECT_MEMORY\}\}/$project_memory}"
    prompt="${prompt//\{\{STALENESS_DAYS\}\}/$STALENESS_DAYS}"
    prompt="${prompt//\{\{REPO_PATH\}\}/${AGENT_REPO_PATH:-}}"
    prompt="${prompt//\{\{AGENT_HOME\}\}/$AGENT_HOME}"

    if [[ "${#prompt}" -le "$PROMPT_BUDGET" ]]; then
        echo "   ✓ Tier 1 (compact agent memory): ${#prompt} chars"
        export AGENT_PROMPT="$prompt"
        return 0
    fi

    # ── Tier 2: Compact project index ─────────────────────────
    if [[ "$AGENT_PROJECT_TYPE" == "workspace" ]]; then
        local compact_index
        compact_index=$(_build_compact_project_index)
        # Rebuild workspace block with compact index
        local workspace_block=""
        workspace_block+="## Workspace Mode"$'\n\n'
        workspace_block+="Multi-project navigation. Switch by reading project memory. Announce: \`[→ Project: <name> (<type>)]\`"$'\n'
        workspace_block+="Create new projects with \`cp -r $AGENT_HOME/templates/new-project $AGENT_HOME/projects/<name>\`"$'\n\n'
        workspace_block+="$compact_index"
        project_memory="$workspace_block"
    fi

    prompt="$core_prompt"
    prompt="${prompt//\{\{PERSONA_BLOCK\}\}/$persona_block}"
    prompt="${prompt//\{\{ROUTER_BLOCK\}\}/$router_block}"
    prompt="${prompt//\{\{TRAIT_REFERENCE\}\}/$trait_reference}"
    prompt="${prompt//\{\{GLOBAL_CONSTRAINTS\}\}/$global_constraints}"
    prompt="${prompt//\{\{PROJECT_CONSTRAINTS\}\}/$project_constraints}"
    prompt="${prompt//\{\{SHARED_MEMORY\}\}/$shared_memory}"
    prompt="${prompt//\{\{AGENT_MEMORY\}\}/$agent_memory}"
    prompt="${prompt//\{\{PROJECT_MEMORY\}\}/$project_memory}"
    prompt="${prompt//\{\{STALENESS_DAYS\}\}/$STALENESS_DAYS}"
    prompt="${prompt//\{\{REPO_PATH\}\}/${AGENT_REPO_PATH:-}}"
    prompt="${prompt//\{\{AGENT_HOME\}\}/$AGENT_HOME}"

    if [[ "${#prompt}" -le "$PROMPT_BUDGET" ]]; then
        echo "   ✓ Tier 2 (compact project index): ${#prompt} chars"
        export AGENT_PROMPT="$prompt"
        return 0
    fi

    # ── Tier 3: Shared memory → abstracts only ────────────────
    shared_memory=$(_load_memory_l0 "$AGENT_HOME/shared/memory")

    prompt="$core_prompt"
    prompt="${prompt//\{\{PERSONA_BLOCK\}\}/$persona_block}"
    prompt="${prompt//\{\{ROUTER_BLOCK\}\}/$router_block}"
    prompt="${prompt//\{\{TRAIT_REFERENCE\}\}/$trait_reference}"
    prompt="${prompt//\{\{GLOBAL_CONSTRAINTS\}\}/$global_constraints}"
    prompt="${prompt//\{\{PROJECT_CONSTRAINTS\}\}/$project_constraints}"
    prompt="${prompt//\{\{SHARED_MEMORY\}\}/$shared_memory}"
    prompt="${prompt//\{\{AGENT_MEMORY\}\}/$agent_memory}"
    prompt="${prompt//\{\{PROJECT_MEMORY\}\}/$project_memory}"
    prompt="${prompt//\{\{STALENESS_DAYS\}\}/$STALENESS_DAYS}"
    prompt="${prompt//\{\{REPO_PATH\}\}/${AGENT_REPO_PATH:-}}"
    prompt="${prompt//\{\{AGENT_HOME\}\}/$AGENT_HOME}"

    if [[ "${#prompt}" -le "$PROMPT_BUDGET" ]]; then
        echo "   ✓ Tier 3 (compact shared memory): ${#prompt} chars"
        export AGENT_PROMPT="$prompt"
        return 0
    fi

    # Still over budget — warn but proceed
    echo "   ⚠ Still over budget after all tiers: ${#prompt} chars (budget: $PROMPT_BUDGET)"
    echo "     Consider reducing core-prompt.md or splitting projects."
    export AGENT_PROMPT="$prompt"
    return 1
}

# ── L1 memory loader (used by both modes) ────────────────────

_load_memory_l1() {
    local dir="$1"
    local output=""
    for mf in "$dir"/*.md; do
        [[ -f "$mf" ]] || continue
        local mf_basename
        mf_basename=$(basename "$mf")

        # Skip template-only files (no real content beyond placeholders)
        local content_lines
        content_lines=$(grep -cvE '^\s*$|^#|^---|^<|^\[.*\]$|^>\s|{{.*}}' "$mf" 2>/dev/null || echo "0")
        if [[ "$content_lines" -lt 5 ]]; then
            # Still list it as available, but don't inline content
            output+="### $mf_basename"$'\n'
            output+="**Path:** \`$mf\` *(template — read on demand)*"$'\n\n'
            continue
        fi

        output+="### $mf_basename"$'\n'
        output+="**Path:** \`$mf\`"$'\n'
        local abstract
        abstract=$(grep "^abstract:" "$mf" 2>/dev/null | head -1 | sed 's/^abstract:[[:space:]]*//' | sed 's/^"//' | sed 's/"$//')
        if [[ -n "$abstract" ]]; then
            output+="**Abstract (L0):** $abstract"$'\n'
        fi
        output+=$(head -50 "$mf")
        output+=$'\n\n'
    done
    echo "$output"
}

# ── Context assembly (single project mode) ───────────────────

assemble_context() {
    local project_dir="$1"
    local project_name
    project_name=$(basename "$project_dir")

    # Read project config
    local project_type
    project_type=$(yaml_get "$project_dir/project.yaml" "type")
    local repo_path
    repo_path=$(yaml_get "$project_dir/project.yaml" "repo_path")
    local default_persona_name
    default_persona_name=$(yaml_get "$project_dir/project.yaml" "default_persona")

    # Determine active persona
    local persona_name="${PERSONA_OVERRIDE:-$default_persona_name}"
    persona_name="${persona_name:-default}"

    # ── Build the system prompt ───────────────────────────────

    local prompt=""
    local core_prompt
    core_prompt=$(cat "$AGENT_HOME/shared/core-prompt.md")

    # Persona block
    local persona_block=""
    local persona_file="$AGENT_HOME/personas/${persona_name}.md"
    if [[ -f "$persona_file" ]]; then
        persona_block=$(cat "$persona_file")
    else
        echo "⚠ Persona '$persona_name' not found, falling back to default."
        persona_block=$(cat "$AGENT_HOME/personas/default.md")
    fi

    # Router block
    local router_block=""
    if [[ "$DYNAMIC_PERSONAS" == "true" ]]; then
        router_block=$(cat "$AGENT_HOME/personas/_router.md")
    fi

    # Global constraints
    local global_constraints=""
    if [[ -f "$AGENT_HOME/shared/constraints.md" ]]; then
        global_constraints=$(cat "$AGENT_HOME/shared/constraints.md")
    fi

    # Project constraints
    local project_constraints=""
    if [[ -f "$project_dir/constraints.md" ]]; then
        project_constraints=$(cat "$project_dir/constraints.md")
    fi

    # User memory (shared/memory/)
    local shared_memory=""
    shared_memory=$(_load_memory_l1 "$AGENT_HOME/shared/memory")

    # Agent memory (shared/agent/)
    local agent_memory=""
    if [[ -d "$AGENT_HOME/shared/agent" ]]; then
        agent_memory=$(_load_memory_l1 "$AGENT_HOME/shared/agent")
    fi

    # Project memory
    local project_memory=""
    project_memory=$(_load_memory_l1 "$project_dir/memory")

    # Resolve repo path
    local resolved_repo="${repo_path/\~/$HOME}"
    resolved_repo="${resolved_repo:-[no repo - this is a non-code project]}"

    # Trait reference (linked, not inline — saves ~6k chars)
    local trait_reference=""
    if [[ -f "$AGENT_HOME/personas/_traits.md" ]]; then
        trait_reference="## Big Five Trait System"$'\n\n'
        trait_reference+="Full trait reference: \`$AGENT_HOME/personas/_traits.md\`"$'\n'
        trait_reference+="Read this file when you need to interpret persona trait scores."
    fi

    # ── Substitute variables in core prompt ───────────────────

    prompt="$core_prompt"
    prompt="${prompt//\{\{PERSONA_BLOCK\}\}/$persona_block}"
    prompt="${prompt//\{\{ROUTER_BLOCK\}\}/$router_block}"
    prompt="${prompt//\{\{TRAIT_REFERENCE\}\}/$trait_reference}"
    prompt="${prompt//\{\{GLOBAL_CONSTRAINTS\}\}/$global_constraints}"
    prompt="${prompt//\{\{PROJECT_CONSTRAINTS\}\}/$project_constraints}"
    prompt="${prompt//\{\{SHARED_MEMORY\}\}/$shared_memory}"
    prompt="${prompt//\{\{AGENT_MEMORY\}\}/$agent_memory}"
    prompt="${prompt//\{\{PROJECT_MEMORY\}\}/$project_memory}"
    prompt="${prompt//\{\{STALENESS_DAYS\}\}/$STALENESS_DAYS}"
    prompt="${prompt//\{\{REPO_PATH\}\}/$resolved_repo}"

    # Export for adapter use
    export AGENT_PROMPT="$prompt"
    export AGENT_PROJECT_NAME="$project_name"
    export AGENT_PROJECT_DIR="$project_dir"
    export AGENT_PROJECT_TYPE="$project_type"
    export AGENT_REPO_PATH="$resolved_repo"
    export AGENT_PERSONA="$persona_name"

    # Budget enforcement
    _BUDGET_PROJECT_CONSTRAINTS="$project_constraints"
    _BUDGET_PROJECT_MEMORY="$project_memory"
    _enforce_budget || true
    export AGENT_HOME="$AGENT_HOME"
}

# ── Main ──────────────────────────────────────────────────────

main() {
    # Handle subcommands
    case "${COMMAND:-}" in
        list)
            cmd_list
            exit 0
            ;;
        new)
            cmd_new "$PROJECT"
            exit 0
            ;;
        check)
            cmd_check "$PROJECT"
            exit 0
            ;;
        summarize)
            cmd_summarize "$PROJECT"
            exit 0
            ;;
        bootstrap)
            local force_flag=""
            [[ "$PROJECT" == "--force" ]] && force_flag="--force"
            bash "$AGENT_HOME/bootstrap.sh" ${force_flag:+"$force_flag"}
            exit 0
            ;;
        heartbeat)
            bash "$AGENT_HOME/heartbeat.sh" "${PROJECT:-}"
            exit 0
            ;;
        import)
            bash "$AGENT_HOME/import.sh" "${PROJECT:-}"
            exit 0
            ;;
        dashboard)
            python3 "$AGENT_HOME/dashboard.py" "${PROJECT:-3141}"
            exit 0
            ;;
    esac

    # Resolve project or enter workspace mode
    if [[ -z "$PROJECT" ]]; then
        if [[ -n "$DEFAULT_PROJECT" && "$DEFAULT_PROJECT" != "null" ]]; then
            PROJECT="$DEFAULT_PROJECT"
        fi
    fi

    if [[ -z "$PROJECT" ]]; then
        # ── Workspace mode (no project selected) ─────────────
        echo "🚀 Starting in workspace mode (all projects available)"
        assemble_workspace_context
        echo "   Persona: $AGENT_PERSONA"
        echo "   Mode: workspace (multi-project)"
        echo "   Adapter: $ADAPTER"
        echo ""
    else
        # ── Single project mode ───────────────────────────────
        local project_dir="$AGENT_HOME/projects/$PROJECT"
        if [[ ! -d "$project_dir" ]]; then
            echo "❌ Project '$PROJECT' not found."
            echo "   Available:"
            cmd_list
            exit 1
        fi

        echo "🚀 Loading project: $PROJECT"
        assemble_context "$project_dir"
        echo "   Persona: $AGENT_PERSONA"
        echo "   Type: $AGENT_PROJECT_TYPE"
        echo "   Adapter: $ADAPTER"
        echo ""

        # Run staleness check (quick, non-blocking)
        cmd_check "$PROJECT" 2>/dev/null || true
    fi

    # Dispatch to adapter
    local adapter_script="$AGENT_HOME/adapters/${ADAPTER}.sh"
    if [[ ! -f "$adapter_script" ]]; then
        echo "❌ Adapter '$ADAPTER' not found at $adapter_script"
        echo "   Available adapters:"
        ls "$AGENT_HOME/adapters/"
        exit 1
    fi

    source "$adapter_script"
    adapter_launch
}

main
